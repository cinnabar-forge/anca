{
  "name": "anca",
  "version": "0.1.0",
  "description": "Organize your workspaces and manage projects deploy fast and easy",
  "keywords": [
    "project manager"
  ],
  "license": "ISC",
  "author": {
    "email": "timur.moziev@gmail.com",
    "name": "Timur Moziev",
    "url": "https://timurrin.github.io/"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "anca": "dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cinnabar-forge/anca.git"
  },
  "scripts": {
    "build:server": "npx tsc --build --verbose",
    "build:web": "vite build",
    "build": "npm run build:server && npm run build:web",
    "check": "biome check ./src && svelte-check --tsconfig ./src/web/tsconfig.json --output human",
    "dev:server": "tsc-watch --onSuccess \"node ./dist/server/index.js\"",
    "dev:web": "vite --host",
    "ds": "npm run dev:server",
    "dw": "npm run dev:web",
    "fix": "biome check --fix --unsafe ./src",
    "prepack": "npm run build",
    "start": "node ./dist/server/index.js",
    "test": "npm run check && npm run build"
  },
  "dependencies": {
    "axios": "1.7.9",
    "cookie-parser": "1.4.7",
    "cors": "2.8.5",
    "dotenv": "16.3.1",
    "express": "4.21.2",
    "jsonwebtoken": "9.0.2",
    "ulid": "2.3.0",
    "unidecode": "1.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@sveltejs/vite-plugin-svelte": "3.0.1",
    "@tsconfig/svelte": "5.0.2",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "9.0.5",
    "@types/unidecode": "^0.1.3",
    "svelte": "4.2.19",
    "svelte-check": "4.1.4",
    "svelte-preprocess": "5.1.3",
    "tsc-watch": "6.0.4",
    "typescript": "5.5.4",
    "vite": "5.4.14"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
